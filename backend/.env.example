# Reddit API Credentials (optional - for Reddit API access)
REDDIT_CLIENT_ID=your_client_id_here
REDDIT_CLIENT_SECRET=your_client_secret_here
REDDIT_USER_AGENT=CommunityAggregator/1.0

# Facebook API Credentials (optional - for Facebook Graph API)
FACEBOOK_APP_ID=your_app_id_here
FACEBOOK_APP_SECRET=your_app_secret_here

# Database
DATABASE_URL=sqlite+aiosqlite:///./communities.db

# API Settings
API_HOST=0.0.0.0
API_PORT=8000

# Scraping Settings
SCRAPE_INTERVAL_HOURS=24
MAX_CONCURRENT_REQUESTS=5
REQUEST_TIMEOUT=30
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36

# Rate Limiting (requests per minute)
DISCORD_RATE_LIMIT=30
REDDIT_RATE_LIMIT=60
TELEGRAM_RATE_LIMIT=30
QUORA_RATE_LIMIT=20
FACEBOOK_RATE_LIMIT=20
